# Gateway
NEXUS_GATEWAY_PORT=3100
NEXUS_GATEWAY_TOKEN=          # Required in production — secures WS connections
NEXUS_DATA_DIR=               # Defaults to ./data

# AI Providers (set the one you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# Strapi Integration
STRAPI_API_URL=               # e.g. https://api.yourapp.com/api
NEXUS_CORS_ORIGINS=           # Comma-separated, e.g. https://app.yourapp.com,https://admin.yourapp.com
