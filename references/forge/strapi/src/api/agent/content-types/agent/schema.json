{
  "kind": "collectionType",
  "collectionName": "agents",
  "info": {
    "singularName": "agent",
    "pluralName": "agents",
    "displayName": "Agent"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "string",
      "required": true
    },
    "enabled": {
      "type": "boolean",
      "default": false
    },
    "focusAreas": {
      "type": "json",
      "default": ["feature-gaps", "journey-completeness", "polish", "accessibility", "ux-improvements"]
    },
    "customInstructions": {
      "type": "text"
    },
    "schedule": {
      "type": "enumeration",
      "enum": ["off", "weekly", "biweekly", "monthly"],
      "default": "off"
    },
    "approvalMode": {
      "type": "enumeration",
      "enum": ["preview", "auto-create"],
      "default": "preview"
    },
    "maxProposals": {
      "type": "integer",
      "default": 10
    },
    "excludeCategories": {
      "type": "json",
      "default": []
    },
    "promptTemplate": {
      "type": "text"
    },
    "reindexPromptTemplate": {
      "type": "text"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "inversedBy": "agents"
    },
    "definition": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::agent-definition.agent-definition",
      "inversedBy": "agents"
    }
  }
}
