{
  "kind": "collectionType",
  "collectionName": "agent_sessions",
  "info": {
    "singularName": "agent-session",
    "pluralName": "agent-sessions",
    "displayName": "AgentSession"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": ["idle", "running", "completed", "failed"],
      "default": "idle"
    },
    "messages": {
      "type": "json",
      "default": []
    },
    "claudeSessionId": {
      "type": "string"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project"
    },
    "repoPath": {
      "type": "string"
    },
    "usage": {
      "type": "json"
    },
    "metadata": {
      "type": "json"
    },
    "diff": {
      "type": "json"
    },
    "issues": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::issue.issue",
      "inversedBy": "agentSessions"
    }
  }
}
