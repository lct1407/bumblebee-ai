{
  "kind": "collectionType",
  "collectionName": "notifications",
  "info": {
    "singularName": "notification",
    "pluralName": "notifications",
    "displayName": "Notification"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": ["issue_status_changed", "comment_added", "agent_completed"],
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "text"
    },
    "read": {
      "type": "boolean",
      "default": false
    },
    "issueDocumentId": {
      "type": "string"
    },
    "agentSessionDocumentId": {
      "type": "string"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project"
    }
  }
}
