# Database
DATABASE_URL=postgresql+asyncpg://bumblebee:bumblebee@localhost:5433/bumblebee

# API
API_HOST=0.0.0.0
API_PORT=8000
# Required. Signs JWTs. Generate with: openssl rand -hex 32
# Rotation procedure: docs/disaster-recovery.md ("Secret rotation")
API_SECRET_KEY=
ENVIRONMENT=development

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_CLI_PATH=claude

# Workspace (where agent worktrees live)
WORKSPACE_ROOT=~/.bumblebee/workspaces

# Defaults (see plan §12 Industry Defaults)
SESSION_WALL_MIN=60
SESSION_TOKENS_MAX=160000
SESSION_DOLLARS_MAX=3.0
ISSUE_DOLLARS_MAX=10.0
PROJECT_DAILY_DOLLARS_MAX=200.0
COMPACTION_THRESHOLD=0.80
RETRY_MAX=3
HEARTBEAT_SECONDS=30
LEASE_TTL_SECONDS=600

# Billing (Stripe)
# Obtain from Stripe Dashboard → Developers → Webhooks → "Signing secret".
# Local dev uses the whsec_... value printed by `stripe listen`.
# Rotation procedure: docs/disaster-recovery.md ("Secret rotation")
STRIPE_WEBHOOK_SECRET=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
EVAL_GOLDEN_DATASET_PATH=./eval/golden.jsonl
