# Caddy reverse proxy — used when not using Cloudflare Tunnel.
# Auto Let's Encrypt + HTTP→HTTPS redirect + WebSocket forwarding.
#
# Substitute ${DOMAIN_API} and ${DOMAIN_WEB} via envsubst before mounting,
# or use ARG-style replacement in the deploy script.

{$DOMAIN_API:api.bb.local} {
    encode gzip
    reverse_proxy api:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        # WebSocket support for /ws
        flush_interval -1
    }
    log {
        output stdout
        format console
    }
}

{$DOMAIN_WEB:bb.local} {
    encode gzip br
    reverse_proxy web:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
    # Long cache for Next.js static assets
    @static {
        path /_next/static/*
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
}
